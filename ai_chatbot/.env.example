DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=coedigo_db
DB_PORT=3306

CHATBOT_HOST=127.0.0.1
CHATBOT_PORT=5000
CHATBOT_TIMEZONE=Asia/Manila
CHATBOT_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
FLASK_DEBUG=0

# Web Search Configuration
CHATBOT_WEB_LOOKUP_ENABLED=1

# Optional: Tavily API for enhanced web search
